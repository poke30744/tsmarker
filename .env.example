# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here
# Optional: Custom API base URL (for Azure OpenAI or other compatible services)
# OPENAI_API_BASE=https://api.openai.com/v1
# Optional: Model name (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Optional: Temperature for LLM (default: 0.1)
# SPEECH_TEMPERATURE=0.1
# Optional: Max tokens for LLM response (default: 2000)
# SPEECH_MAX_TOKENS=2000
# Optional: API timeout in seconds (default: 30.0)
# OPENAI_TIMEOUT=30.0